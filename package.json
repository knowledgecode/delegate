{
  "name": "@knowledgecode/delegate",
  "version": "0.10.4",
  "description": "Event delegation library with support for Web Components.",
  "keywords": [
    "event",
    "delegation",
    "typescript",
    "webcomponents",
    "shadowdom",
    "debounce",
    "throttle",
    "dom",
    "esm",
    "cdn"
  ],
  "homepage": "https://github.com/knowledgecode/delegate#readme",
  "bugs": {
    "url": "https://github.com/knowledgecode/delegate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgecode/delegate.git"
  },
  "license": "MIT",
  "author": "KNOWLEDGECODE",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "build-watch": "vite build -w",
    "dev": "vite",
    "lint": "eslint",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.2",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint": "^10.4.1",
    "lit": "^3.3.3",
    "rollup-plugin-license": "^3.7.1",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.5",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
